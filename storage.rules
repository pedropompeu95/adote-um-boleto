rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Imagens de boletos
    match /boletos/{filename} {

      // Leitura pública (URLs geradas pelo getDownloadURL são já restritas)
      allow read: if request.auth != null;

      // Upload: somente autenticados com e-mail verificado
      // Apenas imagens JPEG/PNG/WebP, máx 5 MB
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');

      // Deleção proibida pela app (arquivo fica vinculado ao boleto)
      allow delete: if false;
    }
  }
}
